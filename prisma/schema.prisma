generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum StockMovementType {
  PURCHASE       // goods received from supplier
  SALE           // goods dispatched on sale
  ADJUSTMENT_IN  // manual stock increase (requires notes)
  ADJUSTMENT_OUT // manual stock decrease (requires notes)
  RETURN_IN      // customer return → stock in
  RETURN_OUT     // supplier return → stock out
  DAILY_IN       // daily log: produced
  DAILY_OUT      // daily log: used / sold / waste / damaged
}

enum DailyLogStatus {
  OPEN
  CLOSED
  REOPENED       // admin reopened; manual edits allowed again
  AUTO_ADJUSTED  // cascade recalculation applied after a backdated change
}


enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED  // voided: sale didn't happen, stock restored
  LOST       // dispatched: goods gone, stock NOT restored, financial obligation waived
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  ESEWA
  KHALTI
  IME_PAY
  FONEPAY
  OTHER
}

enum PayrollStatus {
  DRAFT
  FINALIZED
}

enum ExpenseStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Unit {
  id        String    @id @default(cuid())
  name      String    @unique // e.g. "kg", "pcs", "box", "litre"
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id           String  @id @default(cuid())
  name         String
  sku          String  @unique
  description  String?
  categoryId   String
  unitId       String

  // Pricing
  costPrice    Decimal @default(0) @db.Decimal(10, 2)
  sellingPrice Decimal @default(0) @db.Decimal(10, 2)

  // Packaging — how many pieces are in one packet (null = not applicable)
  piecesPerPacket Int?

  // Stock — updated ONLY via StockMovement, never directly
  currentStock Decimal @default(0) @db.Decimal(10, 3)
  reorderLevel Decimal @default(0) @db.Decimal(10, 3)

  category            Category             @relation(fields: [categoryId], references: [id])
  unit                Unit                 @relation(fields: [unitId], references: [id])
  stockMovements      StockMovement[]
  purchaseOrderItems  PurchaseOrderItem[]
  salesOrderItems     SalesOrderItem[]
  purchaseReturnItems PurchaseReturnItem[]
  salesReturnItems    SalesReturnItem[]
  purchaseLineItems   PurchaseLineItem[]
  dailyLogItems       DailyLogItem[]
  recipe              Recipe?
  recipeIngredients   RecipeIngredient[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId])
  @@index([sku])
}

model Recipe {
  id        String   @id @default(cuid())
  productId String   @unique
  yieldQty  Decimal  @default(1) @db.Decimal(10, 3)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product     Product            @relation(fields: [productId], references: [id])
  ingredients RecipeIngredient[]

  @@index([productId])
}

model RecipeIngredient {
  id         String  @id @default(cuid())
  recipeId   String
  productId  String
  quantity   Decimal @db.Decimal(10, 3)

  recipe  Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([recipeId, productId])
  @@index([recipeId])
  @@index([productId])
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  type           StockMovementType
  quantity       Decimal           @db.Decimal(10, 3) // always positive
  quantityBefore Decimal           @db.Decimal(10, 3)
  quantityAfter  Decimal           @db.Decimal(10, 3)
  unitCost       Decimal?          @db.Decimal(10, 2)
  notes          String? // required for ADJUSTMENT_IN / ADJUSTMENT_OUT
  referenceId    String? // ID of the source document
  referenceType  String? // "PurchaseOrder" | "SalesOrder" | "PurchaseReturn" | "SalesReturn"
  isAdminOverride Boolean          @default(false) // true if negative stock was allowed

  product   Product  @relation(fields: [productId], references: [id])
  createdBy String // Clerk userId
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([referenceId])
  @@index([createdAt])
  @@index([type])
}

model DailyLog {
  id        String         @id @default(cuid())
  logDate   DateTime       @db.Date         // date-only, one log per day
  status    DailyLogStatus @default(OPEN)
  notes     String?
  createdBy String
  closedBy  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  closedAt  DateTime?

  // Set when cascade recalculation auto-adjusts this log
  autoAdjustedAt DateTime?
  autoAdjustedBy String?

  items DailyLogItem[]

  @@unique([logDate])
  @@index([logDate])
  @@index([status])
}

model DailyLogItem {
  id         String   @id @default(cuid())
  dailyLogId String
  productId  String

  openingQty     Decimal @default(0) @db.Decimal(10, 3) // snapshot of currentStock at log creation
  producedQty    Decimal @default(0) @db.Decimal(10, 3)
  usedQty        Decimal @default(0) @db.Decimal(10, 3)
  soldQty        Decimal @default(0) @db.Decimal(10, 3)
  freshReturnQty Decimal @default(0) @db.Decimal(10, 3) // FRESH sales returns restocked today
  wasteQty       Decimal @default(0) @db.Decimal(10, 3)
  damagedQty     Decimal @default(0) @db.Decimal(10, 3)
  closingQty   Decimal @default(0) @db.Decimal(10, 3) // stored when day is closed
  notes        String?

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dailyLogId, productId])
  @@index([dailyLogId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// SUPPLIERS & PURCHASES
// ─────────────────────────────────────────────

model Supplier {
  id          String  @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  pan            String?  // PAN number (Permanent Account Number)
  openingBalance Decimal  @default(0) @db.Decimal(10, 2) // amount owed to vendor before system use

  purchaseOrders  PurchaseOrder[]
  payments        SupplierPayment[]
  purchases       Purchase[]
  vendorPayments  VendorPayment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  orderNumber  String              @unique
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?

  subtotal    Decimal @db.Decimal(10, 2)
  taxAmount   Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)
  amountPaid  Decimal @default(0) @db.Decimal(10, 2) // must never exceed totalAmount

  notes String?

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  items     PurchaseOrderItem[]
  payments  SupplierPayment[]
  returns   PurchaseReturn[]

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal @db.Decimal(10, 3)
  receivedQty     Decimal @default(0) @db.Decimal(10, 3)
  unitCost        Decimal @db.Decimal(10, 2)
  totalCost       Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model PurchaseReturn {
  id              String @id @default(cuid())
  returnNumber    String @unique
  purchaseOrderId String
  reason          String
  totalAmount     Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  items         PurchaseReturnItem[]

  createdBy String
  createdAt DateTime @default(now())
}

model PurchaseReturnItem {
  id               String  @id @default(cuid())
  purchaseReturnId String
  productId        String
  quantity         Decimal @db.Decimal(10, 3)
  unitCost         Decimal @db.Decimal(10, 2)

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])

  @@index([purchaseReturnId])
}

model SupplierPayment {
  id              String        @id @default(cuid())
  purchaseOrderId String
  supplierId      String
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  reference       String?
  notes           String?
  paidAt          DateTime      @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier      @relation(fields: [supplierId], references: [id])

  createdBy String
  createdAt DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([supplierId])
}

/// Standalone vendor payment — not tied to a specific invoice or PO.
/// Used to record credit settlement payments (partial or full).
model VendorPayment {
  id         String        @id @default(cuid())
  supplierId String
  amount     Decimal       @db.Decimal(10, 2)
  method     PaymentMethod
  reference  String?       // cheque no, bank ref, etc.
  notes      String?
  receiptUrl String?       // photo of payment receipt
  paidAt     DateTime      @default(now())

  supplier    Supplier                   @relation(fields: [supplierId], references: [id])
  allocations VendorPaymentAllocation[]

  createdBy String
  createdAt DateTime @default(now())

  @@index([supplierId])
  @@index([paidAt])
}

/// Links a VendorPayment to a specific Purchase invoice (for allocation tracking).
model VendorPaymentAllocation {
  id              String  @id @default(cuid())
  vendorPaymentId String
  purchaseId      String
  amount          Decimal @db.Decimal(10, 2)

  vendorPayment VendorPayment @relation(fields: [vendorPaymentId], references: [id], onDelete: Cascade)
  purchase      Purchase      @relation(fields: [purchaseId],      references: [id])

  @@index([vendorPaymentId])
  @@index([purchaseId])
}

model Purchase {
  id            String   @id @default(cuid())
  invoiceNo     String   @unique
  supplierId    String
  date          DateTime
  paymentMethod String   // "CASH" | "CREDIT"
  subtotal      Decimal  @db.Decimal(10, 2)
  vatTotal      Decimal  @default(0) @db.Decimal(10, 2)
  totalCost     Decimal  @db.Decimal(10, 2)
  amountPaid    Decimal  @default(0) @db.Decimal(10, 2)
  notes         String?
  invoiceUrl    String?

  supplier            Supplier                   @relation(fields: [supplierId], references: [id])
  items               PurchaseLineItem[]
  vendorPaymentAllocs VendorPaymentAllocation[]

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([supplierId])
  @@index([date])
}

model PurchaseLineItem {
  id          String  @id @default(cuid())
  purchaseId  String
  productId   String?
  productName String
  categoryId  String? // for auto-creating new products
  unitId      String? // for auto-creating new products
  description String?
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2)
  grossAmount Decimal @db.Decimal(10, 2)
  vatPct       Decimal @default(0) @db.Decimal(5, 2)
  vatAmount    Decimal @default(0) @db.Decimal(10, 2)
  excisePct    Decimal @default(0) @db.Decimal(5, 2)
  exciseAmount Decimal @default(0) @db.Decimal(10, 2)
  lineTotal    Decimal @db.Decimal(10, 2)

  purchase Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// SALESMEN & SALES
// ─────────────────────────────────────────────

model Salesman {
  id             String    @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  pan            String?   // PAN number
  dob            DateTime? // Date of birth
  citizenshipNo  String?   // Citizenship certificate number
  photo          String?   // Profile photo URL
  openingBalance Decimal   @default(0) @db.Decimal(10, 2)
  commissionPct  Decimal   @default(25.00) @db.Decimal(5, 2)

  salesOrders SalesOrder[]
  payments    SalesmanPayment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("Customer")
}

model SalesOrder {
  id          String           @id @default(cuid())
  orderNumber String           @unique
  customerId  String
  status      SalesOrderStatus @default(DRAFT)
  orderDate   DateTime         @default(now())
  dueDate     DateTime?

  subtotal         Decimal @db.Decimal(10, 2)
  taxAmount        Decimal @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal @db.Decimal(10, 2)
  amountPaid       Decimal @default(0) @db.Decimal(10, 2) // must never exceed factoryAmount

  // Commission fields — snapshot from customer at dispatch time
  commissionPct    Decimal @default(25.00) @db.Decimal(5, 2)  // e.g. 25.00 or 30.00
  commissionAmount Decimal @default(0) @db.Decimal(10, 2)     // commissionPct% of net amount
  factoryAmount    Decimal @default(0) @db.Decimal(10, 2)     // (100 - commissionPct)% of net amount

  notes String?

  salesman Salesman         @relation(fields: [customerId], references: [id])
  items    SalesOrderItem[]
  payments SalesmanPayment[]
  returns  SalesReturn[]

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([customerId])
  @@index([status])
  @@index([orderDate])
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  productId    String
  quantity     Decimal @db.Decimal(10, 3)
  unitPrice    Decimal @db.Decimal(10, 2)
  totalPrice   Decimal @db.Decimal(10, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@index([productId])
}

model SalesReturn {
  id           String   @id @default(cuid())
  returnNumber String   @unique
  salesOrderId String
  notes        String?
  totalAmount  Decimal  @db.Decimal(10, 2)
  returnType   String   @default("WASTE") // "WASTE" | "FRESH"

  salesOrder SalesOrder      @relation(fields: [salesOrderId], references: [id])
  items      SalesReturnItem[]

  createdBy String
  createdAt DateTime @default(now())
}

model SalesReturnItem {
  id            String  @id @default(cuid())
  salesReturnId String
  productId     String
  quantity      Decimal @db.Decimal(10, 3)
  unitPrice     Decimal @db.Decimal(10, 2)

  salesReturn SalesReturn @relation(fields: [salesReturnId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])

  @@index([salesReturnId])
}

model SalesmanPayment {
  id           String        @id @default(cuid())
  salesOrderId String
  customerId   String
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod
  reference    String?
  notes        String?
  paidAt       DateTime      @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  salesman   Salesman   @relation(fields: [customerId], references: [id])

  createdBy String
  createdAt DateTime @default(now())

  @@index([salesOrderId])
  @@index([customerId])
  @@map("CustomerPayment")
}

// ─────────────────────────────────────────────
// EMPLOYEES & PAYROLL
// ─────────────────────────────────────────────

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
}

model Employee {
  id            String    @id @default(cuid())
  employeeNo    String    @unique
  firstName     String
  lastName      String
  email         String?   @unique
  phone         String
  citizenshipId String?
  address       String?
  departmentId  String
  position       String
  basicSalary    Decimal   @db.Decimal(10, 2)
  openingBalance Decimal   @default(0) @db.Decimal(10, 2)
  startDate      DateTime
  endDate       DateTime? // set when employee leaves

  clerkUserId String? @unique // links to Clerk user if they have app access

  department   Department         @relation(fields: [departmentId], references: [id])
  payrollItems PayrollItem[]
  withdrawals  SalaryWithdrawal[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
  @@index([clerkUserId])
}

model SalaryWithdrawal {
  id          String   @id @default(cuid())
  employeeId  String
  amount      Decimal  @db.Decimal(10, 2)
  takenAt     DateTime @default(now())
  filedBy     String?  // name of person who filed/recorded this entry
  givenBy     String?  // name of person who physically handed the cash
  paymentMode String   @default("CASH") // "CASH" or "ONLINE"
  notes       String?
  photoUrl    String?  // proof of payment photo

  employee         Employee          @relation(fields: [employeeId], references: [id])
  appliedDeduction PayrollDeduction? // null until applied to a payroll run
  recordedBy       String            // Clerk userId
  createdAt        DateTime          @default(now())

  @@index([employeeId])
  @@index([takenAt])
}

model PayrollRun {
  id     String        @id @default(cuid())
  month  Int // 1–12
  year   Int
  status PayrollStatus @default(DRAFT)
  notes  String?

  items PayrollItem[]

  createdBy String
  updatedBy String? // Clerk userId of last person to modify this run
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year]) // DB-enforced: one run per month
}

model PayrollItem {
  id           String  @id @default(cuid())
  payrollRunId String
  employeeId   String
  basicSalary  Decimal @db.Decimal(10, 2)
  carryoverIn  Decimal @default(0) @db.Decimal(10, 2) // outstanding salary carried from previous month
  allowances   Decimal @default(0) @db.Decimal(10, 2)
  deductions   Decimal @default(0) @db.Decimal(10, 2) // total amount paid out in partial payments
  netPay       Decimal @db.Decimal(10, 2)             // remaining = basicSalary + carryoverIn − deductions
  notes        String?

  payrollRun       PayrollRun        @relation(fields: [payrollRunId], references: [id])
  employee         Employee          @relation(fields: [employeeId], references: [id])
  deductionEntries PayrollDeduction[]

  @@unique([payrollRunId, employeeId]) // one payslip per employee per run
  @@index([payrollRunId])
  @@index([employeeId])
}

model PayrollDeduction {
  id            String   @id @default(cuid())
  payrollItemId String
  amount        Decimal  @db.Decimal(10, 2)
  givenBy       String?
  givenAt       DateTime @default(now()) // date the money was physically handed
  paymentMode   String   @default("CASH") // "CASH" or "ONLINE"
  notes         String?
  photoUrl      String?
  recordedBy    String   // Clerk userId
  createdAt     DateTime @default(now())

  // When set, this deduction applies a prior SalaryWithdrawal — the cash already
  // left the business on the withdrawal date. NOT a new cash outflow in Cash Flow.
  withdrawalId  String?  @unique

  payrollItem PayrollItem       @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  withdrawal  SalaryWithdrawal? @relation(fields: [withdrawalId], references: [id])

  @@index([payrollItemId])
}

// ─────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Expense {
  id            String        @id @default(cuid())
  categoryId    String
  description   String
  amount        Decimal       @db.Decimal(10, 2)
  date          DateTime
  status        ExpenseStatus @default(SUBMITTED)
  notes         String?
  attachmentUrl String?

  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  submittedBy String // Clerk userId
  approvedBy  String? // Clerk userId

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId])
  @@index([status])
  @@index([date])
}

// ─────────────────────────────────────────────
// ACCESS REQUESTS
// ─────────────────────────────────────────────

model AccessRequest {
  id           String              @id @default(cuid())
  fullName     String
  workEmail    String
  department   String
  jobTitle     String
  phone        String?
  reason       String?
  status       AccessRequestStatus @default(PENDING)
  reviewedBy   String?             // Clerk userId of admin who actioned it
  reviewNote   String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// RECEIPTS (money borrowed / received by company)
// ─────────────────────────────────────────────

model Receipt {
  id            String        @id @default(cuid())
  receiptNumber String        @unique
  receivedFrom  String        // name of person or entity
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  reference     String?       // cheque no, bank ref, etc.
  notes         String?
  photoUrl      String?       // optional proof photo
  receivedAt    DateTime      @default(now())

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([receivedAt])
}

// ─────────────────────────────────────────────
// RECEIPT PAYMENTS (money paid back / disbursed from receipt pool)
// ─────────────────────────────────────────────

model ReceiptPayment {
  id            String        @id @default(cuid())
  paymentNumber String        @unique
  paidTo        String        // name of person or entity paid
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  reference     String?       // cheque no, bank ref, etc.
  notes         String?
  photoUrl      String?
  paidAt        DateTime      @default(now())

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([paidAt])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String // Clerk userId
  action     String // e.g. "CONFIRM_SALES_ORDER", "FINALIZE_PAYROLL"
  entityType String // e.g. "SalesOrder", "PayrollRun"
  entityId   String?
  before     Json? // state snapshot before change
  after      Json? // state snapshot after change
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// COMPANY SETTINGS (singleton row, id = "main")
// ─────────────────────────────────────────────

model CompanySettings {
  id          String   @id @default("main")
  name        String
  nameShort   String
  slogan      String
  address     String
  phone       String
  pan         String
  owner       String
  established Int
  updatedAt          DateTime @updatedAt
  updatedBy          String?
  cashOpeningBalance Decimal  @default(0) @db.Decimal(12, 2)
}

// ─────────────────────────────────────────────
// DOCUMENT COUNTERS (atomic sequence per prefix)
// ─────────────────────────────────────────────

model DocumentCounter {
  prefix    String   @id
  nextVal   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
