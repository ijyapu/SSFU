# ══════════════════════════════════════════════════════════════
# SSFU ERP — Environment Variable Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git.
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# CLERK — Authentication
# Get these from: clerk.com → Your SSFU project → API Keys
# ──────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Get this from: clerk.com → Your SSFU project → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_replace_me

# ──────────────────────────────────────────────
# SUPABASE — Database + File Storage
# Get these from: supabase.com → Your SSFU project → Settings → API
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci_replace_me

# Get from: supabase.com → Settings → Database → Connection string
# DATABASE_URL  = Transaction pooler (used at runtime)
# DIRECT_URL    = Direct connection  (used for migrations only)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ──────────────────────────────────────────────
# EMAIL — Resend (optional — leave blank to disable email notifications)
# Get from: resend.com → API Keys
# ──────────────────────────────────────────────
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=noreply@ssfu.work
ADMIN_EMAIL=admin@example.com

# ──────────────────────────────────────────────
# APP — General
# ──────────────────────────────────────────────
# The public URL of this app (used in email links and security headers)
NEXT_PUBLIC_APP_URL=https://your-ssfu-domain.vercel.app

# ──────────────────────────────────────────────
# SENTRY — Error tracking (optional — leave these unset to disable)
# ──────────────────────────────────────────────
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=sntrys_replace_me
